# Backend
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://seeyou:seeyou_dev@127.0.0.1:5432/seeyou
# SurrealDB HTTP endpoint (ws://.../rpc is auto-normalized for backward compatibility)
SURREALDB_URL=http://127.0.0.1:8000
SURREALDB_NAMESPACE=seeyou
SURREALDB_DATABASE=graph
SURREALDB_USERNAME=root
SURREALDB_PASSWORD=root
# Primary broker endpoint (legacy-compatible with REDPANDA_URL)
REDPANDA_BROKERS=127.0.0.1:19092
REDPANDA_URL=127.0.0.1:19092
# Optional split for Railway/private vs public networking:
# - outside Railway, REDPANDA_BROKERS_PUBLIC is preferred if REDPANDA_BROKERS points to *.railway.internal
# - inside Railway, REDPANDA_BROKERS/REDPANDA_BROKERS_INTERNAL remains preferred
REDPANDA_BROKERS_PUBLIC=
REDPANDA_BROKERS_INTERNAL=
# Optional Kafka/Redpanda security overrides (leave empty for local plaintext setup)
REDPANDA_SECURITY_PROTOCOL=
REDPANDA_SASL_MECHANISM=
REDPANDA_SASL_USERNAME=
REDPANDA_SASL_PASSWORD=
REDPANDA_SSL_CA_LOCATION=
REDPANDA_SSL_CERT_LOCATION=
REDPANDA_SSL_KEY_LOCATION=
REDPANDA_SSL_KEY_PASSWORD=
SCHEMA_REGISTRY_URL=http://127.0.0.1:18081
BUS_ENABLED=false
BUS_FALLBACK_MODE=redis_postgres
TOMTOM_API_KEY=your_tomtom_api_key_here

# Frontend (prefixed VITE_ for Vite exposure)
VITE_WS_URL=ws://localhost:3001/ws
VITE_API_URL=http://localhost:3001
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here
VITE_OPENWEATHER_API_KEY=your_openweathermap_api_key
VITE_WAQI_TOKEN=your_waqi_token
